# ============================================
#   ORION — AI Classroom Agent Configuration
# ============================================

# Telegram Bot Token (dari BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (isi setelah tahu ID Anda)
# Cara: Jalankan bot lalu ketik /start → ID akan tampil
TELEGRAM_OWNER_ID=

# Google AI / Gemini API Key
# Buat di: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# Google OAuth 2.0 Credentials
# Buat di: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://localhost:3000/auth/callback

# Bot Settings
CHECK_INTERVAL_MINUTES=15

# Daily Digest Settings (jam berapa digest harian dikirim, 0-23)
DAILY_DIGEST_HOUR=7

# Timezone untuk daily digest
TIMEZONE=Asia/Jakarta

# OpenRouter (Fallback for Gemini)
OPENROUTER_API_KEY=

# ==============================================================
# KONFIGURASI ABSENSI OTOMATIS (ETHOL PENS)
# ==============================================================
ETHOL_EMAIL=
ETHOL_PASSWORD=


# Keamanan Multi-User ETHOL
ENCRYPTION_KEY=

# Path browser untuk Puppeteer (opsional — auto-detect Chrome/Edge jika dikosongkan)
# Uncomment dan isi jika auto-detect gagal (misal: Windows 8 dengan Chrome di lokasi custom)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
